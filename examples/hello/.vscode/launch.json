{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "dezog",
            "request": "launch",
            "name": "Simulator",
            "remoteType": "zrcp",
            "zrcp": {
                "port": 10001,
            },

            "sjasmplus": [
                {
                    "path": "main.sld",
                },

                {
                    "path": "cpm/cpm.sld",
                    "srcDirs": [
                        "cpm/"
                    ]
                },
                {
                    "path": "mon/monitor.sld",
                    "srcDirs": [
                        "mon/"
                    ]
                }
            ],
            "smartDisassemblerArgs": {
                "lowerCase": false
            },
            // "disassemblerArgs": {
            //     "numberOfLines": 10
            // },
            "history": {
                "reverseDebugInstructionCount": 20,
                "spotCount": 10,
                "codeCoverageEnabled": true
            },
            "startAutomatically": false,
            "commandsAfterLaunch": [
                //"-rmv",
                "-mv 0x100 0x80"
            ],
            "rootFolder": "${workspaceFolder}",
            "topOfStack": "stack",
            "loadObjs": [
                {
                    "path": "main.obj",
                    "start": "0x0100"
                }
            ],
            "execAddress": "0x0100",
            "smallValuesMaximum": 513,
            "tmpDir": ".tmp"
        }
    ]
}